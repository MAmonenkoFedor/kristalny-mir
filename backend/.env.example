# Порт API
PORT=4000

# Источник фронтенда для CORS
FRONTEND_ORIGIN=http://localhost:3000

# ── Доступ в админку (логин + пароль) ─────────────────────────
# Эти значения используются для создания администратора при первом запуске
# (сидинг). После создания пароль хранится в БД в виде хэша.
ADMIN_EMAIL=admin@kristalnymir.by
ADMIN_PASSWORD=change-me-please
# Секрет для подписи JWT — ОБЯЗАТЕЛЬНО смените на длинную случайную строку.
JWT_SECRET=change-me-to-a-long-random-string

# Подключение к БД (SQLite-файл)
DATABASE_URL="file:./dev.db"

# ── Уведомления на email (SMTP) ───────────────────────────────
# Для Gmail: включите 2FA и создайте «Пароль приложения»
# (https://myaccount.google.com/apppasswords), его и вставьте в SMTP_PASS.
# Если оставить пустыми — email-уведомления просто отключатся.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=crystalizor@gmail.com
SMTP_PASS=
MAIL_TO=crystalizor@gmail.com
MAIL_FROM="Кристальный Мир" <crystalizor@gmail.com>

# ── Уведомления в Telegram ────────────────────────────────────
# 1) Создайте бота у @BotFather → получите токен.
# 2) Напишите боту любое сообщение, затем узнайте chat_id
#    (например, через @userinfobot или getUpdates).
# Если оставить пустыми — TG-уведомления отключатся.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
